                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"rating\": 5,\n  \"comment\": \"Great place!\"\n}",
                            "options": { "raw": { "language": "json" } }
                        },
                        "url": "{{base_url}}/api/v1/properties/{{property_id}}/reviews"
                    }
                }
            ]
        },

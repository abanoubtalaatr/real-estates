                                { "key": "listing_type", "value": "sale",       "disabled": true },
                                { "key": "search",       "value": "apartment",  "disabled": true },
                                { "key": "latitude",     "value": "30.0444",    "disabled": true },
                                { "key": "longitude",    "value": "31.2357",    "disabled": true },
                                { "key": "radius_km",    "value": "50",         "disabled": true }
                            ]
                        }
                    }
                },

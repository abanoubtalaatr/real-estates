{
    "info": {
        "_postman_id": "f1a2b3c4-d5e6-7890-abcd-ef1234567890",
        "name": "RealEstates – User API",
        "description": "All user endpoints. Set {{base_url}} to your API root (e.g. http://localhost:8000). After login, paste token into {{token}}.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        { "key": "base_url",        "value": "http://localhost:8000" },
        { "key": "token",           "value": "" },
        { "key": "property_id",     "value": "1" },
        { "key": "property_slug",   "value": "sunny-downtown-apartment-abc123" },
        { "key": "conversation_id", "value": "1" },
        { "key": "agent_user_id",   "value": "3" }
    ],
    "item": [
        {
            "name": "Auth",
            "item": [
                {
                    "name": "Register",
                    "request": {
                        "method": "POST",
                        "header": [
                            { "key": "Accept",       "value": "application/json" },
                            { "key": "Content-Type", "value": "application/json" }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password\",\n  \"password_confirmation\": \"password\"\n}",
                            "options": { "raw": { "language": "json" } }
                        },
                        "url": "{{base_url}}/api/v1/auth/register"
                    }
                },
                {
                    "name": "Login",
                    "request": {
                        "method": "POST",
                        "header": [
                            { "key": "Accept",       "value": "application/json" },
                            { "key": "Content-Type", "value": "application/json" }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"buyer@example.com\",\n  \"password\": \"password\"\n}",
                            "options": { "raw": { "language": "json" } }
                        },
                        "url": "{{base_url}}/api/v1/auth/login"
                    }
                },
                {
                    "name": "Login with Google",
                    "request": {
                        "method": "POST",
                        "header": [
                            { "key": "Accept",       "value": "application/json" },
                            { "key": "Content-Type", "value": "application/json" }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"id_token\": \"GOOGLE_ID_TOKEN_FROM_FLUTTER\"\n}",
                            "options": { "raw": { "language": "json" } }
                        },
                        "url": "{{base_url}}/api/v1/auth/google"
                    }
                },
                {
                    "name": "Logout",
                    "request": {
                        "method": "POST",
                        "header": [
                            { "key": "Accept",         "value": "application/json" },
                            { "key": "Authorization",  "value": "Bearer {{token}}" }
                        ],
                        "url": "{{base_url}}/api/v1/auth/logout"
                    }
                },
                {
                    "name": "Me (get profile)",
                    "request": {
                        "method": "GET",
                        "header": [
                            { "key": "Accept",        "value": "application/json" },
                            { "key": "Authorization", "value": "Bearer {{token}}" }
                        ],
                        "url": "{{base_url}}/api/v1/auth/me"
                    }
                },
                {
                    "name": "Update Profile",
                    "request": {
                        "method": "PUT",
                        "header": [
                            { "key": "Accept",        "value": "application/json" },
                            { "key": "Content-Type",  "value": "application/json" },
                            { "key": "Authorization", "value": "Bearer {{token}}" }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"John Updated\",\n  \"location\": \"Cairo\",\n  \"phone\": \"+201000000000\"\n}",
                            "options": { "raw": { "language": "json" } }
                        },
                        "url": "{{base_url}}/api/v1/auth/profile"
                    }
                },
                {
                    "name": "Change Password",
                    "request": {
                        "method": "PUT",
                        "header": [
                            { "key": "Accept",        "value": "application/json" },
                            { "key": "Content-Type",  "value": "application/json" },
                            { "key": "Authorization", "value": "Bearer {{token}}" }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"current_password\": \"password\",\n  \"password\": \"newpassword\",\n  \"password_confirmation\": \"newpassword\"\n}",
                            "options": { "raw": { "language": "json" } }
                        },
                        "url": "{{base_url}}/api/v1/auth/password"
                    }
                },
                {
                    "name": "Forgot Password (Send OTP)",
                    "request": {
                        "method": "POST",
                        "header": [
                            { "key": "Accept",       "value": "application/json" },
                            { "key": "Content-Type", "value": "application/json" }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"buyer@example.com\"\n}",
                            "options": { "raw": { "language": "json" } }
                        },
                        "url": "{{base_url}}/api/v1/auth/forgot-password"
                    }
                },
                {
                    "name": "Verify OTP",
                    "request": {
                        "method": "POST",
                        "header": [
                            { "key": "Accept",       "value": "application/json" },
                            { "key": "Content-Type", "value": "application/json" }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"buyer@example.com\",\n  \"otp\": \"123456\"\n}",
                            "options": { "raw": { "language": "json" } }
                        },
                        "url": "{{base_url}}/api/v1/auth/verify-otp"
                    }
                },
                {
                    "name": "Reset Password",
                    "request": {
                        "method": "POST",
                        "header": [
                            { "key": "Accept",       "value": "application/json" },
                            { "key": "Content-Type", "value": "application/json" }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"buyer@example.com\",\n  \"otp\": \"123456\",\n  \"password\": \"newpassword\",\n  \"password_confirmation\": \"newpassword\"\n}",
                            "options": { "raw": { "language": "json" } }
                        },
                        "url": "{{base_url}}/api/v1/auth/reset-password"
                    }
                },
                {
                    "name": "Delete Account",
                    "request": {
                        "method": "DELETE",
                        "header": [
                            { "key": "Accept",        "value": "application/json" },
                            { "key": "Authorization", "value": "Bearer {{token}}" }
                        ],
                        "url": "{{base_url}}/api/v1/auth/account"
                    }
                }
            ]
        },
        {
            "name": "Properties",
            "item": [
                {
                    "name": "Home Page",
                    "request": {
                        "method": "GET",

                },
                {
                    "name": "Get Property by Slug",
                    "request": {
                        "method": "GET",
                        "header": [
                            { "key": "Accept", "value": "application/json" }
                        ],
                        "url": "{{base_url}}/api/v1/properties/{{property_slug}}"
                    }
                },
                {
                    "name": "Similar Properties",

                        ],
                        "url": "{{base_url}}/api/v1/home"
                    }
                },
                {
                    "name": "List Properties",
                    "request": {
                        "method": "GET",
                        "header": [
                            { "key": "Accept", "value": "application/json" }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/v1/properties?page=1&per_page=15",
                            "query": [
                                { "key": "page",         "value": "1" },
                                { "key": "per_page",     "value": "15" },

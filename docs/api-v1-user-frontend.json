{
  "meta": {
    "title": "Real Estate API v1 — User & Public (Frontend)",
    "version": "1.0.0",
    "description": "Contract for web/mobile apps: discovery, auth, profile, favorites, orders (Stripe checkout URL), reviews, chat. Admin routes under /admin are not included here.",
    "baseUrl": "{{API_BASE_URL}}/api/v1",
    "variables": {
      "API_BASE_URL": "https://your-api-domain.com",
      "FRONTEND_URL": "https://your-spa-domain.com",
      "TOKEN": "paste_token_from_login_or_register_response",
      "PROPERTY_ID": 1,
      "PROPERTY_SLUG_OR_ID": "sunny-downtown-apartment-abc123",
      "CONVERSATION_ID": 1,
      "ORDER_ID": 1,
      "PAGE": 1,
      "PER_PAGE": 15
    },
    "authentication": {
      "type": "Bearer",
      "headerName": "Authorization",
      "headerValueTemplate": "Bearer {{TOKEN}}",
      "howToObtain": "POST /auth/login or POST /auth/register returns data.token. Send on every protected request.",
      "logout": "POST /auth/logout with Bearer deletes the current token."
    },
    "enums": {
      "userRole": ["user", "admin", "agent"],
      "listingType": ["sale", "rent"],
      "propertyStatus": ["draft", "published"],
      "orderStatus": ["pending", "paid", "failed", "cancelled"]
    },
    "pagination": {
      "laravelDefault": "Paginated list responses use Laravel pagination JSON: data[], links{}, meta{current_page,from,last_page,links,path,per_page,to,total}. Geo search on properties uses custom meta (see that endpoint)."
    },
    "notes": [
      "Password reset emails link to FRONTEND_URL/reset-password?token=...&email=... (configure FRONTEND_URL on backend).",
      "Image URLs in responses are built from storage/public; ensure API_BASE_URL or a CDN matches your deployed storage URL.",
      "POST /orders returns payment_url when STRIPE_SECRET is configured; otherwise order is still created as pending.",
      "Stripe webhook POST /stripe/webhook is server-to-server only — do not call from the browser."
    ]
  },
  "endpoints": [
    {
      "id": "home",
      "group": "public.discovery",
      "method": "GET",
      "path": "/home",
      "requiresAuth": false,
      "description": "Featured categories, best-selling, featured, and recommended published properties.",
      "response": {
        "data": {
          "categories": [{ "id": 0, "name": "", "slug": "", "description": null, "sort_order": 0 }],
          "best_selling": ["{{propertyResource}}"],
          "featured": ["{{propertyResource}}"],
          "recommended": ["{{propertyResource}}"]
        }
      },
      "schemas": {
        "propertyResource": {
          "id": 0,
          "title": "",
          "slug": "",
          "description": null,
          "price": "0.00",
          "listing_type": "sale",
          "status": "published",
          "bedrooms": 0,
          "bathrooms": 0,
          "kitchens": 0,
          "is_featured": false,
          "sales_count": 0,
          "latitude": null,
          "longitude": null,
          "address": null,
          "distance_km": "only_when_nearby_search",
          "category": { "id": 0, "name": "", "slug": "", "description": null, "sort_order": 0 },
          "images": [{ "id": 0, "url": "", "sort_order": 0 }],
          "agent": {
            "id": 0,
            "title": null,
            "bio": null,
            "license_number": null,
            "company": null,
            "user": { "id": 0, "name": "", "email": "", "role": "agent", "location": null, "phone": null, "created_at": "" }
          }
        }
      }
    },
    {
      "id": "properties_index",
      "group": "public.discovery",
      "method": "GET",
      "path": "/properties",
      "requiresAuth": false,
      "queryParams": {
        "category_id": { "type": "integer", "optional": true, "example": "{{PROPERTY_ID}}" },
        "listing_type": { "type": "string", "optional": true, "enum": ["sale", "rent"] },
        "search": { "type": "string", "optional": true, "description": "Matches property title (partial)." },
        "latitude": { "type": "number", "optional": true, "requiresWith": ["longitude"], "example": 30.0444 },
        "longitude": { "type": "number", "optional": true, "requiresWith": ["latitude"], "example": 31.2357 },
        "radius_km": { "type": "number", "optional": true, "default": 50, "min": 1, "max": 200, "note": "Only used with latitude+longitude; sorts by distance." },
        "page": { "type": "integer", "optional": true, "default": 1 },
        "per_page": { "type": "integer", "optional": true, "default": 15, "max": 50 }
      },
      "response": {
        "whenNoGeo": "Laravel paginated PropertyResource collection",
        "whenGeo": {
          "data": ["{{propertyResource}} with distance_km"],
          "meta": { "current_page": 1, "per_page": 15, "total": 0, "last_page": 1 }
        }
      }
    },
    {
      "id": "property_show",
      "group": "public.discovery",
      "method": "GET",
      "path": "/properties/{{PROPERTY_SLUG_OR_ID}}",
      "requiresAuth": false,
      "pathParams": {
        "property": "Numeric id OR slug string (published only)."
      },
      "response": { "data": "{{propertyResource}}" }
    },
    {
      "id": "property_similar",
      "group": "public.discovery",
      "method": "GET",
      "path": "/properties/{{PROPERTY_ID}}/similar",
      "requiresAuth": false,
      "pathParams": { "property": "Integer id only." },
      "response": { "data": ["{{propertyResource}}"] }
    },
    {
      "id": "property_reviews_index",
      "group": "public.reviews",
      "method": "GET",
      "path": "/properties/{{PROPERTY_ID}}/reviews",
      "requiresAuth": false,
      "pathParams": { "property": "Integer id (published property)." },
      "queryParams": {
        "page": { "optional": true },
        "per_page": { "optional": true, "default": 15 }
      },
      "response": {
        "paginated": true,
        "itemShape": {
          "id": 0,
          "rating": 1,
          "comment": null,
          "created_at": "",
          "user": { "id": 0, "name": "", "email": "", "role": "user", "location": null, "phone": null, "created_at": "" }
        }
      }
    },
    {
      "id": "auth_register",
      "group": "auth",
      "method": "POST",
      "path": "/auth/register",
      "requiresAuth": false,
      "body": {
        "name": "string required",
        "email": "string required unique",
        "password": "string required",
        "password_confirmation": "string required must match password"
      },
      "response": {
        "data": {
          "user": "{{userResource}}",
          "token": "plain_text_token_save_in_memory",
          "token_type": "Bearer"
        }
      },
      "schemas": {
        "userResource": {
          "id": 0,
          "name": "",
          "email": "",
          "role": "user",
          "location": null,
          "phone": null,
          "created_at": ""
        }
      }
    },
    {
      "id": "auth_login",
      "group": "auth",
      "method": "POST",
      "path": "/auth/login",
      "requiresAuth": false,
      "body": { "email": "string required", "password": "string required" },
      "errors": { "422": { "message": "Invalid credentials." }, "403": { "message": "Account is blocked." } },
      "response": {
        "data": {
          "user": "{{userResource}}",
          "token": "plain_text_token",
          "token_type": "Bearer"
        }
      }
    },
    {
      "id": "auth_forgot_password",
      "group": "auth",
      "method": "POST",
      "path": "/auth/forgot-password",
      "requiresAuth": false,
      "body": { "email": "string required" },
      "response": {
        "message": "If an account exists for that email, a reset link has been sent."
      }
    },
    {
      "id": "auth_reset_password",
      "group": "auth",
      "method": "POST",
      "path": "/auth/reset-password",
      "requiresAuth": false,
      "body": {
        "token": "from_email_query_string",
        "email": "from_email_query_string",
        "password": "string required",
        "password_confirmation": "string required"
      },
      "response": { "message": "Password has been reset." }
    },
    {
      "id": "auth_logout",
      "group": "auth",
      "method": "POST",
      "path": "/auth/logout",
      "requiresAuth": true,
      "response": { "message": "Logged out." }
    },
    {
      "id": "auth_me",
      "group": "auth",
      "method": "GET",
      "path": "/auth/me",
      "requiresAuth": true,
      "response": { "data": "{{userResource}}" }
    },
    {
      "id": "auth_profile_update",
      "group": "auth",
      "method": "PUT",
      "path": "/auth/profile",
      "requiresAuth": true,
      "body": {
        "name": { "optional": "string" },
        "location": { "optional": "string|null" },
        "phone": { "optional": "string|null" }
      },
      "response": { "data": "{{userResource}}" }
    },
    {
      "id": "auth_password_change",
      "group": "auth",
      "method": "PUT",
      "path": "/auth/password",
      "requiresAuth": true,
      "body": {
        "current_password": "string required must match existing",
        "password": "string required",
        "password_confirmation": "string required"
      },
      "response": { "message": "Password updated." }
    },
    {
      "id": "auth_account_delete",
      "group": "auth",
      "method": "DELETE",
      "path": "/auth/account",
      "requiresAuth": true,
      "response": { "message": "Account deleted." }
    },
    {
      "id": "me_recommendations",
      "group": "user.personalization",
      "method": "GET",
      "path": "/me/recommendations",
      "requiresAuth": true,
      "description": "Based on favorite/order categories; random published picks if none.",
      "response": { "data": ["{{propertyResource}}"] }
    },
    {
      "id": "favorites_index",
      "group": "user.favorites",
      "method": "GET",
      "path": "/favorites",
      "requiresAuth": true,
      "queryParams": { "page": {}, "per_page": {} },
      "response": { "paginated": true, "data": ["{{propertyResource}}"] }
    },
    {
      "id": "favorites_store",
      "group": "user.favorites",
      "method": "POST",
      "path": "/favorites",
      "requiresAuth": true,
      "body": { "property_id": "integer required exists published" },
      "response": { "data": { "id": 0 }, "status": "201 if created, 200 if already existed" }
    },
    {
      "id": "favorites_destroy",
      "group": "user.favorites",
      "method": "DELETE",
      "path": "/favorites/{{PROPERTY_ID}}",
      "requiresAuth": true,
      "pathParams": { "property": "integer property id" },
      "response": { "message": "Removed from favorites." }
    },
    {
      "id": "orders_index",
      "group": "user.orders",
      "method": "GET",
      "path": "/orders",
      "requiresAuth": true,
      "queryParams": { "page": {}, "per_page": {} },
      "response": {
        "paginated": true,
        "itemShape": {
          "id": 0,
          "amount": "0.00",
          "currency": "usd",
          "status": "pending",
          "stripe_checkout_session_id": null,
          "created_at": "",
          "property": "{{propertyResource}}"
        }
      }
    },
    {
      "id": "orders_store",
      "group": "user.orders",
      "method": "POST",
      "path": "/orders",
      "requiresAuth": true,
      "body": { "property_id": "integer required" },
      "errors": {
        "422": "Property not published",
        "409": "Pending order already exists for this property"
      },
      "response": {
        "data": {
          "order": {
            "id": 0,
            "amount": "0.00",
            "currency": "usd",
            "status": "pending",
            "stripe_checkout_session_id": "nullable",
            "created_at": "",
            "property": "{{propertyResource}}"
          },
          "payment_url": "string|null redirect user in browser when present"
        }
      }
    },
    {
      "id": "property_reviews_store",
      "group": "user.reviews",
      "method": "POST",
      "path": "/properties/{{PROPERTY_ID}}/reviews",
      "requiresAuth": true,
      "pathParams": { "property": "integer id" },
      "body": {
        "rating": "integer required 1-5",
        "comment": "string optional max 2000"
      },
      "response": {
        "data": {
          "id": 0,
          "rating": 5,
          "comment": null,
          "created_at": "",
          "user": "{{userResource}}"
        }
      },
      "note": "Upserts one review per user per property."
    },
    {
      "id": "conversations_index",
      "group": "user.chat",
      "method": "GET",
      "path": "/conversations",
      "requiresAuth": true,
      "description": "Lists threads where the current user is buyer OR agent.",
      "queryParams": { "page": {}, "per_page": {} },
      "response": {
        "paginated": true,
        "itemShape": {
          "id": 0,
          "user": "{{userResource}}",
          "agent_user": "{{userResource}}",
          "property": "{{propertyResource}} or null fields if unloaded",
          "messages": "array when loaded on show endpoint",
          "updated_at": ""
        }
      }
    },
    {
      "id": "conversations_store",
      "group": "user.chat",
      "method": "POST",
      "path": "/conversations",
      "requiresAuth": true,
      "body": {
        "agent_user_id": "integer required must be user with role agent",
        "property_id": "integer optional"
      },
      "errors": { "422": "Not an agent or invalid self-conversation" },
      "response": { "data": "{{conversationShape}}" }
    },
    {
      "id": "conversations_show",
      "group": "user.chat",
      "method": "GET",
      "path": "/conversations/{{CONVERSATION_ID}}",
      "requiresAuth": true,
      "pathParams": { "conversation": "integer id" },
      "description": "Includes messages with sender.",
      "response": {
        "data": {
          "id": 0,
          "user": "{{userResource}}",
          "agent_user": "{{userResource}}",
          "property": "{{propertyResource}}",
          "messages": [
            {
              "id": 0,
              "body": "",
              "read_at": null,
              "created_at": "",
              "sender": "{{userResource}}"
            }
          ],
          "updated_at": ""
        }
      }
    },
    {
      "id": "messages_store",
      "group": "user.chat",
      "method": "POST",
      "path": "/conversations/{{CONVERSATION_ID}}/messages",
      "requiresAuth": true,
      "pathParams": { "conversation": "integer id" },
      "body": { "body": "string required max 5000" },
      "errors": { "403": "User not a participant" },
      "response": {
        "data": {
          "id": 0,
          "body": "",
          "read_at": null,
          "created_at": "",
          "sender": "{{userResource}}"
        }
      }
    }
  ],
  "frontendSnippets": {
    "axiosBase": {
      "baseURL": "{{API_BASE_URL}}/api/v1",
      "headersCommon": {
        "Accept": "application/json",
        "Content-Type": "application/json"
      },
      "headersWithAuth": {
        "Accept": "application/json",
        "Content-Type": "application/json",
        "Authorization": "Bearer {{TOKEN}}"
      }
    },
    "fetchLoginExample": "await fetch(`${API_BASE_URL}/api/v1/auth/login`, { method: 'POST', headers: { 'Accept': 'application/json', 'Content-Type': 'application/json' }, body: JSON.stringify({ email, password }) })",
    "fetchAuthenticatedExample": "await fetch(`${API_BASE_URL}/api/v1/auth/me`, { headers: { 'Accept': 'application/json', 'Authorization': `Bearer ${token}` } })",
    "multipartNote": "Admin property create uses multipart for images; the user-facing app does not upload listing images."
  }
}
